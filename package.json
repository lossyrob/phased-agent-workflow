{
  "name": "paw-workflow",
  "displayName": "PAW Workflow",
  "description": "Phased Agent Workflow tooling for VS Code - streamlines work item initialization",
  "version": "0.0.2-dev",
  "publisher": "paw-workflow",
  "repository": {
    "type": "git",
    "url": "https://github.com/lossyrob/phased-agent-workflow"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "workflow",
    "ai",
    "agent",
    "productivity"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "PAW Workflow",
      "properties": {
        "paw.agentDirectory": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the user agent directory. When set, PAW installs agents here instead of using the default `~/.copilot/agents` location."
        },
        "paw.promptDirectory": {
          "type": "string",
          "default": "",
          "markdownDescription": "Deprecated fallback for legacy prompt-directory installs. When set and `paw.agentDirectory` is empty, PAW installs agents here instead of using `~/.copilot/agents`."
        },
        "paw.enableWorktreeExecution": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable dedicated worktree execution mode during PAW workflow initialization. Enabled by default; disable to always use the current checkout."
        }
      }
    },
    "commands": [
      {
        "command": "paw.initializeWorkItem",
        "title": "New PAW Workflow",
        "category": "PAW"
      },
      {
        "command": "paw.getWorkStatus",
        "title": "Get Work Status",
        "category": "PAW"
      },
      {
        "command": "paw.stopTrackingArtifacts",
        "title": "Stop Tracking Artifacts",
        "category": "PAW"
      }
    ],
    "chatPromptFiles": [
      {
        "path": "./prompts/paw-review.prompt.md"
      },
      {
        "path": "./prompts/paw.prompt.md"
      }
    ],
    "chatSkills": [
      {
        "path": "./vscode-assets/skills/paw-code-research/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-docs-guidance/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-final-review/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-git-operations/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-impl-review/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-implement/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-init/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-lite/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-plan-review/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-planning/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-planning-docs-review/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-pr/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-review-baseline/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-review-correlation/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-review-critic/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-review-feedback/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-review-gap/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-review-github/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-review-impact/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-review-response/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-review-understanding/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-review-workflow/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-rewind/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-sot/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-spec/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-spec-research/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-spec-review/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-status/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-transition/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-work-shaping/SKILL.md"
      },
      {
        "path": "./vscode-assets/skills/paw-workflow/SKILL.md"
      }
    ],
    "languageModelTools": [
      {
        "name": "paw_new_session",
        "displayName": "Start New PAW Session",
        "modelDescription": "Start a fresh PAW agent chat session with cleared context. Use for session resets, stage transitions, or when user requests 'clear context' / 'new session'. Includes Work ID context and optional inline instructions.",
        "toolReferenceName": "pawHandoff",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "properties": {
            "target_agent": {
              "type": "string",
              "description": "The exact name of the PAW agent to invoke",
              "enum": [
                "PAW",
                "PAW-Review"
              ]
            },
            "work_id": {
              "type": "string",
              "description": "The normalized Work ID (feature slug, e.g., 'auth-system')"
            },
            "inline_instruction": {
              "type": "string",
              "description": "Optional instruction to pass to the target agent (e.g., 'Phase 2', 'add rate limiting')"
            }
          },
          "required": [
            "target_agent",
            "work_id"
          ]
        }
      }
    ]
  },
  "scripts": {
    "clean:out": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\"",
    "clean:vscode-assets": "node -e \"require('fs').rmSync('vscode-assets', { recursive: true, force: true })\"",
    "precompile": "npm run clean:out && npm run clean:vscode-assets",
    "postcompile": "node ./scripts/render-vscode-skills.js",
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "node ./scripts/watch-vscode-assets.js",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "lint:agent": "./scripts/lint-prompting.sh",
    "lint:agent:all": "./scripts/lint-prompting.sh --all",
    "lint:skills": "./scripts/lint-prompting.sh --skills",
    "build-vsix": "./scripts/build-vsix.sh",
    "count-tokens": "node ./scripts/count-tokens.js",
    "test:integration": "cd tests/integration && npx tsx --test tests/**/*.test.ts",
    "test:integration:skills": "cd tests/integration && npx tsx --test tests/skills/*.test.ts",
    "test:integration:workflows": "cd tests/integration && npx tsx --test tests/workflows/*.test.ts"
  },
  "devDependencies": {
    "@dqbd/tiktoken": "^1.0.0",
    "@playwright/test": "^1.57.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^18.x",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.56.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
